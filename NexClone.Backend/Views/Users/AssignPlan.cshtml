@model NexClone.Backend.Models.ApplicationUser

@{
    ViewData["Title"] = "Assign Plan";
}

<div class="bx--grid bx--grid--full-width">
    <div class="bx--row">
        <div class="bx--col">
            <h1 class="bx--type-productive-heading-05" style="margin-bottom: 2rem;">Assign Plan to @Model.Email</h1>
        </div>
    </div>

    <div class="bx--row">
        <div class="bx--col-lg-6">
            <form asp-action="AssignPlan" method="post">
                <input type="hidden" name="userId" value="@Model.Id" />
                
                <div class="bx--form-item" style="margin-bottom: 2rem;">
                    <label for="planId" class="bx--label">Select a Plan</label>
                    <div class="bx--select">
                        <select id="planId" name="planId" class="bx--select-input" required>
                            <option value="" disabled selected hidden>Choose an option</option>
                            @if (ViewBag.Plans != null)
                            {
                                foreach (var item in (SelectList)ViewBag.Plans)
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        </select>
                        <svg focusable="false" preserveAspectRatio="xMidYMid meet" style="will-change: transform;" xmlns="http://www.w3.org/2000/svg" class="bx--select__arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M8 11L3 6 3.7 5.3 8 9.6 12.3 5.3 13 6z"></path></svg>
                    </div>
                </div>

                <div style="display: flex; gap: 1rem;">
                    <a href="@Url.Action("Index")" class="bx--btn bx--btn--secondary">Cancel</a>
                    <button type="submit" class="bx--btn bx--btn--primary">Assign Plan</button>
                </div>
            </form>
        </div>
    </div>
</div>
