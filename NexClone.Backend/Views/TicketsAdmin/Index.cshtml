@model IEnumerable<NexClone.Backend.Models.SupportTicket>

<div class="bx--grid" style="padding-left: 0; padding-right: 0;">
    <div class="bx--row">
        <div class="bx--col">
            <div class="bx--data-table-container">
                <table class="bx--data-table" style="width: 100%; text-align: left; background-color: white; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.05);">
                    <thead style="background-color: #f4f4f4;">
                        <tr>
                            <th style="padding: 1rem; border-bottom: 2px solid #e0e0e0;">ID</th>
                            <th style="padding: 1rem; border-bottom: 2px solid #e0e0e0;">User</th>
                            <th style="padding: 1rem; border-bottom: 2px solid #e0e0e0;">Subject</th>
                            <th style="padding: 1rem; border-bottom: 2px solid #e0e0e0;">Status</th>
                            <th style="padding: 1rem; border-bottom: 2px solid #e0e0e0;">Last Updated</th>
                            <th style="padding: 1rem; border-bottom: 2px solid #e0e0e0;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr style="border-bottom: 1px solid #e0e0e0;">
                                <td style="padding: 1rem;">#@item.Id</td>
                                <td style="padding: 1rem;">@item.User.Email</td>
                                <td style="padding: 1rem;">@item.Subject</td>
                                <td style="padding: 1rem;">
                                    @{
                                        string badgeColor = item.Status == "Open" ? "#da1e28" : item.Status == "InProgress" ? "#f1c21b" : "#24a148";
                                    }
                                    <span style="background-color: @badgeColor; color: white; padding: 0.25rem 0.75rem; border-radius: 12px; font-size: 0.75rem; font-weight: 600;">@item.Status</span>
                                </td>
                                <td style="padding: 1rem;">@item.UpdatedAt.ToLocalTime().ToString("g")</td>
                                <td style="padding: 1rem;">
                                    <a href="/TicketsAdmin/Chat/@item.Id" class="bx--btn bx--btn--sm bx--btn--primary" style="background-color: #0f62fe; color: white; padding: 0.5rem 1rem; text-decoration: none; border-radius: 4px; font-size: 0.875rem;">View Chat</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
