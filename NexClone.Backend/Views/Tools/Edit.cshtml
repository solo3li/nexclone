@model NexClone.Backend.Models.Legacy.ToolsTool

@{
    ViewData["Title"] = "Edit AI Tool";
}

<div class="bx--grid" style="padding-left: 0; max-width: 800px; margin-left: 0;">
    <div class="bx--row" style="margin-bottom: 2rem;">
        <h2 style="margin: 0; font-weight: 400; font-size: 1.5rem;">@ViewData["Title"]</h2>
    </div>

    <form asp-action="Edit" method="post" style="background: #ffffff; padding: 2rem; border: 1px solid #e0e0e0;">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="CreatedAt" />

        <div style="display: grid; grid-template-columns: 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
            <div class="bx--form-item">
                <label for="Name" class="bx--label">Tool Identifier (Name)</label>
                <div class="bx--text-input__field-wrapper">
                    <input id="Name" type="text" class="bx--text-input" asp-for="Name" required>
                </div>
                <div class="bx--form__helper-text">Internal identifier, e.g., 'gpt' or 'bg-remover'</div>
            </div>
            
            <div class="bx--form-item">
                <label for="Description" class="bx--label">Description</label>
                <div class="bx--text-input__field-wrapper">
                    <input id="Description" type="text" class="bx--text-input" asp-for="Description" required>
                </div>
            </div>
            
            <div class="bx--form-item">
                <label for="CreditCost" class="bx--label">Credit Cost</label>
                <div class="bx--text-input__field-wrapper">
                    <input id="CreditCost" type="number" step="0.01" min="0" class="bx--text-input" asp-for="CreditCost" required>
                </div>
                <div class="bx--form__helper-text">How many credits this tool consumes per usage unit (e.g., per generation, per 100KB).</div>
            </div>
        </div>

        <div style="display: flex; justify-content: flex-end; gap: 1rem;">
            <a href="@Url.Action("Index")" class="bx--btn bx--btn--secondary">Cancel</a>
            <button type="submit" class="bx--btn bx--btn--primary">Save Changes</button>
        </div>
    </form>
</div>
