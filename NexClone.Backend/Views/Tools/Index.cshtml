@model IEnumerable<NexClone.Backend.Models.Legacy.ToolsTool>

@{
    ViewData["Title"] = "AI Tools Management";
}

<div class="bx--data-table-container">
    <div class="bx--data-table-header">
        <h4 class="bx--data-table-header__title">Manage AI Tools</h4>
        <p class="bx--data-table-header__description">View and manage all available AI tools from the legacy system.</p>
    </div>

    <table class="bx--data-table bx--data-table--sort">
        <thead>
            <tr>
                <th><span class="bx--table-header-label">ID</span></th>
                <th><span class="bx--table-header-label">Tool Name</span></th>
                <th><span class="bx--table-header-label">Description</span></th>
                <th><span class="bx--table-header-label">Credit Cost</span></th>
                <th><span class="bx--table-header-label">Status</span></th>
                <th><span class="bx--table-header-label">Created At</span></th>
                <th><span class="bx--table-header-label">Actions</span></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td><strong>@item.Name</strong></td>
                    <td>@item.Description</td>
                    <td><strong>@item.CreditCost</strong></td>
                    <td>
                        @if (item.IsActive)
                        {
                            <span style="color: green; font-weight: bold;">Active</span>
                        }
                        else
                        {
                            <span style="color: orange; font-weight: bold;">Under Maintenance</span>
                        }
                    </td>
                    <td>@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="bx--btn bx--btn--primary bx--btn--sm" style="padding: 5px 10px; font-size: 12px; height: auto; min-height: unset; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; margin-right: 5px;">
                            Edit
                        </a>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this tool?');">
                            <button type="submit" class="bx--btn bx--btn--danger bx--btn--sm" style="padding: 5px 10px; font-size: 12px; height: auto; min-height: unset;">
                                Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
