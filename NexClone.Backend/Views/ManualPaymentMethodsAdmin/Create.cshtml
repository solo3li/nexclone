@model NexClone.Backend.Models.ManualPaymentMethod

<div class="card">
    <div class="card-body">
        <form action="/ManualPaymentMethodsAdmin/Create" method="post" hx-boost="true">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label>Name (e.g. Vodafone Cash)</label>
                <input type="text" name="Name" class="form-control" required />
            </div>
            <div class="form-group">
                <label>Account Details (e.g. 01012345678)</label>
                <input type="text" name="AccountDetails" class="form-control" required />
            </div>
            <div class="form-group">
                <label>Instructions</label>
                <textarea name="Instructions" class="form-control" rows="3"></textarea>
            </div>
            <div class="form-group" style="margin-top: 1rem;">
                <label>
                    <input type="checkbox" name="IsActive" value="true" checked />
                    Active
                </label>
                <input type="hidden" name="IsActive" value="false" />
            </div>
            <div style="margin-top: 1rem;">
                <button type="submit" class="btn btn-primary">Save</button>
                <a href="/ManualPaymentMethodsAdmin" class="btn btn-secondary" hx-boost="true">Cancel</a>
            </div>
        </form>
    </div>
</div>
