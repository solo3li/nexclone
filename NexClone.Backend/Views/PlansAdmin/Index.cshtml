@model IEnumerable<NexClone.Backend.Models.Plan>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>@ViewData["Title"]</h2>
    <a href="@Url.Action("Create")" class="btn btn-primary">Add New Plan</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Duration (Days)</th>
                        <th>Price (USD)</th>
                        <th>Price (EGP)</th>
                        <th>TTS Limit (Chars)</th>
                        <th>STT Limit (Mins)</th>
                        <th>Images Limit</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.Name</strong></td>
                            <td>@item.DurationDays</td>
                            <td>$@item.PriceUsd</td>
                            <td>EGP @item.PriceEgp</td>
                            <td>@item.MaxTtsCharacters</td>
                            <td>@item.MaxSttMinutes</td>
                            <td>@item.MaxImagesGenerated</td>
                            <td class="text-end">
                                <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-sm btn-outline-secondary">Edit</a>
                                <form action="@Url.Action("Delete", new { id = item.Id })" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this plan?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            @if (!Model.Any())
            {
                <div class="text-center py-4 text-muted">No plans found. Create one to get started.</div>
            }
        </div>
    </div>
</div>
