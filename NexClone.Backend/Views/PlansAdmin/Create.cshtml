@model NexClone.Backend.Models.Plan

<div class="bx--grid" style="padding-left: 0; max-width: 800px; margin-left: 0;">
    <div class="bx--row" style="margin-bottom: 2rem;">
        <h2 style="margin: 0; font-weight: 400; font-size: 1.5rem;">@ViewData["Title"]</h2>
    </div>

    <form action="@Url.Action("Create")" method="post" style="background: #ffffff; padding: 2rem; border: 1px solid #e0e0e0;">
        @Html.AntiForgeryToken()

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
            <div class="bx--form-item">
                <label for="Name" class="bx--label">Plan Name</label>
                <div class="bx--text-input__field-wrapper">
                    <input id="Name" type="text" class="bx--text-input" name="Name" required value="@Model?.Name">
                </div>
            </div>
            <div class="bx--form-item">
                <label for="DurationDays" class="bx--label">Duration (Days)</label>
                <div class="bx--text-input__field-wrapper">
                    <input id="DurationDays" type="number" class="bx--text-input" name="DurationDays" required min="1" value="@(Model?.DurationDays ?? 30)">
                </div>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem;">
            <div class="bx--form-item">
                <label for="PriceUsd" class="bx--label">Price (USD)</label>
                <div class="bx--text-input__field-wrapper">
                    <input id="PriceUsd" type="number" class="bx--text-input" name="PriceUsd" required min="0" step="0.01" value="@(Model?.PriceUsd ?? 0)">
                </div>
            </div>
            <div class="bx--form-item">
                <label for="PriceEgp" class="bx--label">Price (EGP)</label>
                <div class="bx--text-input__field-wrapper">
                    <input id="PriceEgp" type="number" class="bx--text-input" name="PriceEgp" required min="0" step="0.01" value="@(Model?.PriceEgp ?? 0)">
                </div>
            </div>
        </div>

        <hr style="border: none; border-top: 1px solid #e0e0e0; margin-bottom: 2rem;">
        <h4 style="margin-bottom: 1.5rem; font-weight: 400; font-size: 1.25rem;">Economy Limits</h4>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2.5rem;">
            <div class="bx--form-item">
                <label for="MonthlyCredits" class="bx--label">Monthly Credits</label>
                <div class="bx--text-input__field-wrapper">
                    <input id="MonthlyCredits" type="number" class="bx--text-input" name="MonthlyCredits" required min="0" step="0.01" value="@(Model?.MonthlyCredits ?? 0)">
                </div>
                <div class="bx--form__helper-text">Credits granted per month</div>
            </div>
            <div class="bx--form-item">
                <label class="bx--label">Allowed Tools</label>
                <div style="max-height: 200px; overflow-y: auto; border: 1px solid #e0e0e0; padding: 1rem; background: #f4f4f4;">
                    @if(ViewBag.Tools != null) {
                        foreach(var tool in ViewBag.Tools) {
                            <div style="margin-bottom: 0.5rem; display: flex; align-items: center; justify-content: space-between;">
                                <div style="display: flex; align-items: center; gap: 0.5rem;">
                                    <input type="checkbox" id="tool_@tool.Id" name="SelectedTools" value="@tool.Name" class="bx--checkbox" style="cursor: pointer;" onchange="document.getElementById('limit_@tool.Id').style.display = this.checked ? 'block' : 'none';" />
                                    <label for="tool_@tool.Id" class="bx--checkbox-label" style="cursor: pointer; margin: 0; font-size: 0.875rem;">@tool.Name</label>
                                </div>
                                <input type="number" id="limit_@tool.Id" name="ToolLimits[@tool.Name]" value="-1" class="bx--text-input" style="width: 100px; display: none;" placeholder="Limit (-1 for unlim)" />
                            </div>
                        }
                    }
                </div>
                <div class="bx--form__helper-text">Tools included in this plan</div>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr; gap: 1.5rem; margin-bottom: 2rem;">
            <div class="bx--form-item">
                <div style="display: flex; align-items: center; gap: 0.5rem;">
                    <input type="hidden" name="IsFreeTrial" value="false" />
                    <input type="checkbox" id="IsFreeTrial" name="IsFreeTrial" value="true" class="bx--checkbox" @(Model?.IsFreeTrial == true ? "checked" : "") style="cursor: pointer;" />
                    <label for="IsFreeTrial" class="bx--checkbox-label" style="cursor: pointer; margin: 0; font-weight: bold;">Is this a Free Trial plan?</label>
                </div>
                <div class="bx--form__helper-text">If checked, this plan will be automatically assigned to new users upon registration.</div>
            </div>
        </div>

        <div style="display: flex; justify-content: flex-end; gap: 1rem;">
            <a href="@Url.Action("Index")" class="bx--btn bx--btn--secondary">Cancel</a>
            <button type="submit" class="bx--btn bx--btn--primary">Save Plan</button>
        </div>
    </form>
</div>
