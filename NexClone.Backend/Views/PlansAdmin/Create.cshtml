@model NexClone.Backend.Models.Plan

<div class="mb-4">
    <h2>@ViewData["Title"]</h2>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form action="@Url.Action("Create")" method="post">
            @Html.AntiForgeryToken()

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="Name" class="form-label">Plan Name</label>
                    <input type="text" class="form-control" id="Name" name="Name" required value="@Model?.Name">
                </div>
                <div class="col-md-6 mb-3">
                    <label for="DurationDays" class="form-label">Duration (Days)</label>
                    <input type="number" class="form-control" id="DurationDays" name="DurationDays" required min="1" value="@(Model?.DurationDays ?? 30)">
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="PriceUsd" class="form-label">Price (USD)</label>
                    <input type="number" class="form-control" id="PriceUsd" name="PriceUsd" required min="0" step="0.01" value="@(Model?.PriceUsd ?? 0)">
                </div>
                <div class="col-md-6 mb-3">
                    <label for="PriceEgp" class="form-label">Price (EGP)</label>
                    <input type="number" class="form-control" id="PriceEgp" name="PriceEgp" required min="0" step="0.01" value="@(Model?.PriceEgp ?? 0)">
                </div>
            </div>

            <hr class="my-4">
            <h5 class="mb-3">Usage Limits</h5>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label for="MaxTtsCharacters" class="form-label">TTS Characters</label>
                    <input type="number" class="form-control" id="MaxTtsCharacters" name="MaxTtsCharacters" required min="0" value="@(Model?.MaxTtsCharacters ?? 0)">
                    <div class="form-text">Maximum characters for Text-to-Speech</div>
                </div>
                <div class="col-md-4 mb-3">
                    <label for="MaxSttMinutes" class="form-label">STT Minutes</label>
                    <input type="number" class="form-control" id="MaxSttMinutes" name="MaxSttMinutes" required min="0" value="@(Model?.MaxSttMinutes ?? 0)">
                    <div class="form-text">Maximum minutes for Voice-to-Text</div>
                </div>
                <div class="col-md-4 mb-3">
                    <label for="MaxImagesGenerated" class="form-label">Images Generated</label>
                    <input type="number" class="form-control" id="MaxImagesGenerated" name="MaxImagesGenerated" required min="0" value="@(Model?.MaxImagesGenerated ?? 0)">
                    <div class="form-text">Maximum images for AI Generation</div>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-4">
                <a href="@Url.Action("Index")" class="btn btn-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary">Save Plan</button>
            </div>
        </form>
    </div>
</div>
