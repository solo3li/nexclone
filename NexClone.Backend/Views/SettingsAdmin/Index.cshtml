@model IEnumerable<NexClone.Backend.Models.AppSetting>

<div class="bx--grid" style="padding-left: 0; max-width: 800px; margin-left: 0;">
    <div class="bx--row" style="margin-bottom: 2rem;">
        <h2 style="margin: 0; font-weight: 400; font-size: 1.5rem;">@ViewData["Title"]</h2>
        <p style="color: #525252; margin-top: 0.5rem;">Manage site configurations, maintenance modes, and Minio storage.</p>
    </div>

    <form action="@Url.Action("SaveAll", "SettingsAdmin")" method="post" style="background: #ffffff; padding: 2rem; border: 1px solid #e0e0e0;">
        @Html.AntiForgeryToken()

        <h3 style="margin-bottom: 1rem; border-bottom: 1px solid #e0e0e0; padding-bottom: 0.5rem;">Site Settings</h3>
        
        <div class="bx--form-item bx--checkbox-wrapper" style="margin-bottom: 1.5rem;">
            @{
                var maintenanceModeStr = Model.FirstOrDefault(s => s.Key == "Site.MaintenanceMode")?.Value ?? "false";
                bool isMaintenanceMode = bool.TryParse(maintenanceModeStr, out var m) && m;
            }
            <input type="hidden" name="settings[Site.MaintenanceMode]" value="false" id="hidden_Site_MaintenanceMode" />
            <input id="Site_MaintenanceMode" class="bx--checkbox" type="checkbox" value="true" name="settings[Site.MaintenanceMode]" @(isMaintenanceMode ? "checked" : "") onchange="document.getElementById('hidden_Site_MaintenanceMode').disabled = this.checked;">
            <label for="Site_MaintenanceMode" class="bx--checkbox-label" title="Enable Global Maintenance Mode">
                <span class="bx--checkbox-label-text">Enable Global Maintenance Mode (Will show maintenance screen to all users)</span>
            </label>
            <script>document.getElementById('hidden_Site_MaintenanceMode').disabled = document.getElementById('Site_MaintenanceMode').checked;</script>
        </div>

        <div class="bx--form-item" style="margin-bottom: 2rem;">
            <label for="Site_MaintenanceEndDate" class="bx--label">Maintenance End Date (Optional)</label>
            <input id="Site_MaintenanceEndDate" type="datetime-local" class="bx--text-input" name="settings[Site.MaintenanceEndDate]" value="@Model.FirstOrDefault(s => s.Key == "Site.MaintenanceEndDate")?.Value" placeholder="YYYY-MM-DDTHH:MM">
            <div class="bx--form__helper-text">Leave blank for indefinite maintenance.</div>
        </div>

        <h3 style="margin-bottom: 1rem; border-bottom: 1px solid #e0e0e0; padding-bottom: 0.5rem; margin-top: 2rem;">Tools Maintenance</h3>
        <p style="color: #525252; margin-bottom: 1rem; font-size: 0.875rem;">Enable maintenance mode for specific tools. This will show a maintenance screen to users attempting to access them.</p>

        @if (ViewBag.ToolConfigurations != null)
        {
            var tools = (IEnumerable<NexClone.Backend.Models.ToolConfiguration>)ViewBag.ToolConfigurations;
            foreach (var tool in tools)
            {
                <div class="bx--form-item bx--checkbox-wrapper" style="margin-bottom: 1rem;">
                    <input id="toolMaintenance_@(tool.Id)" class="bx--checkbox" type="checkbox" name="toolMaintenance_@(tool.Id)" value="true" @(tool.IsMaintenanceMode ? "checked" : "")>
                    <label for="toolMaintenance_@(tool.Id)" class="bx--checkbox-label" title="Enable Maintenance Mode for @tool.ToolName">
                        <span class="bx--checkbox-label-text">@tool.ToolName (Provider: @tool.ProviderName)</span>
                    </label>
                </div>
            }
        }

        <h3 style="margin-bottom: 1rem; border-bottom: 1px solid #e0e0e0; padding-bottom: 0.5rem; margin-top: 2rem;">Origin (CORS) Settings</h3>
        
        <div class="bx--form-item" style="margin-bottom: 2rem;">
            <label for="Origin_AllowedOrigins" class="bx--label">Allowed Origins</label>
            <input id="Origin_AllowedOrigins" type="text" class="bx--text-input" name="settings[Origin.AllowedOrigins]" value="@Model.FirstOrDefault(s => s.Key == "Origin.AllowedOrigins")?.Value" placeholder="http://localhost:3000,https://nexclone.com">
            <div class="bx--form__helper-text">Comma-separated list of allowed origins. Use * to allow all (not recommended).</div>
        </div>

        <h3 style="margin-bottom: 1rem; border-bottom: 1px solid #e0e0e0; padding-bottom: 0.5rem; margin-top: 2rem;">Minio Settings</h3>
        
        <div class="bx--form-item" style="margin-bottom: 1.5rem;">
            <label for="Minio_Endpoint" class="bx--label">Endpoint</label>
            <input id="Minio_Endpoint" type="text" class="bx--text-input" name="settings[Minio.Endpoint]" value="@Model.FirstOrDefault(s => s.Key == "Minio.Endpoint")?.Value">
        </div>

        <div class="bx--form-item" style="margin-bottom: 1.5rem;">
            <label for="Minio_AccessKey" class="bx--label">Access Key</label>
            <input id="Minio_AccessKey" type="text" class="bx--text-input" name="settings[Minio.AccessKey]" value="@Model.FirstOrDefault(s => s.Key == "Minio.AccessKey")?.Value">
        </div>

        <div class="bx--form-item" style="margin-bottom: 1.5rem;">
            <label for="Minio_SecretKey" class="bx--label">Secret Key</label>
            <input id="Minio_SecretKey" type="password" class="bx--text-input" name="settings[Minio.SecretKey]" value="@Model.FirstOrDefault(s => s.Key == "Minio.SecretKey")?.Value">
        </div>

        <div class="bx--form-item" style="margin-bottom: 2rem;">
            <label for="Minio_BucketName" class="bx--label">Bucket Name</label>
            <input id="Minio_BucketName" type="text" class="bx--text-input" name="settings[Minio.BucketName]" value="@Model.FirstOrDefault(s => s.Key == "Minio.BucketName")?.Value">
        </div>

        <div style="display: flex; justify-content: flex-end; gap: 1rem; margin-top: 2rem;">
            <button type="submit" class="bx--btn bx--btn--primary">Save Settings</button>
        </div>
    </form>
</div>
