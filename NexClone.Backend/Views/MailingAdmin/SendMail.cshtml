@model NexClone.Backend.Controllers.SendMailViewModel
@{
    ViewData["Title"] = "Send Broadcast Email";
    var templates = ViewBag.Templates as IEnumerable<NexClone.Backend.Models.EmailTemplate>;
}

<div class="bx--grid">
    <div class="bx--row">
        <div class="bx--col-lg-8">
            <h2 class="mb-4">Send Mail / Broadcast</h2>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="bx--inline-notification bx--inline-notification--success mb-4" role="alert">
                    <div class="bx--inline-notification__details">
                        <svg focusable="false" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="bx--inline-notification__icon" width="20" height="20" viewBox="0 0 20 20" aria-hidden="true"><path d="M10,1c-4.9,0-9,4.1-9,9s4.1,9,9,9s9-4.1,9-9S14.9,1,10,1z M8.7,13.5l-3.2-3.2l1-1l2.2,2.2l4.8-4.8l1,1L8.7,13.5z"></path></svg>
                        <div class="bx--inline-notification__text-wrapper">
                            <p class="bx--inline-notification__title">Success</p>
                            <p class="bx--inline-notification__subtitle">@TempData["SuccessMessage"]</p>
                        </div>
                    </div>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="bx--inline-notification bx--inline-notification--error mb-4" role="alert">
                    <div class="bx--inline-notification__details">
                        <svg focusable="false" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="bx--inline-notification__icon" width="20" height="20" viewBox="0 0 20 20" aria-hidden="true"><path d="M10,1c-4.9,0-9,4.1-9,9s4.1,9,9,9s9-4.1,9-9S14.9,1,10,1z M10.8,13.5H9.2V12h1.6V13.5z M10.8,10.5H9.2V6.5h1.6V10.5z"></path></svg>
                        <div class="bx--inline-notification__text-wrapper">
                            <p class="bx--inline-notification__title">Error</p>
                            <p class="bx--inline-notification__subtitle">@TempData["ErrorMessage"]</p>
                        </div>
                    </div>
                </div>
            }

            <form asp-action="SendMail" method="post" style="background: #fff; padding: 2rem; border-radius: 8px; border: 1px solid #e0e0e0;" id="sendMailForm">
                <div class="bx--form-item mb-4">
                    <label asp-for="TargetUserEmail" class="bx--label">Target User Email (Leave blank to send to ALL users)</label>
                    <div class="bx--text-input__field-outer-wrapper">
                        <div class="bx--text-input__field-wrapper">
                            <input asp-for="TargetUserEmail" class="bx--text-input" placeholder="user@example.com" />
                        </div>
                    </div>
                </div>

                <div class="bx--form-item mb-4">
                    <label asp-for="TemplateId" class="bx--label">Use Email Template (Optional)</label>
                    <div class="bx--select">
                        <select asp-for="TemplateId" class="bx--select-input" id="templateSelect">
                            <option value="">-- Custom Email --</option>
                            @if(templates != null)
                            {
                                foreach(var t in templates)
                                {
                                    <option value="@t.Id" data-subject="@t.Subject" data-body="@t.HtmlBody">@t.Name</option>
                                }
                            }
                        </select>
                        <svg focusable="false" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="bx--select__arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M8 11L3 6 3.7 5.3 8 9.6 12.3 5.3 13 6z"></path></svg>
                    </div>
                </div>

                <div id="customEmailFields">
                    <div class="bx--form-item mb-4">
                        <label asp-for="Subject" class="bx--label">Subject</label>
                        <div class="bx--text-input__field-outer-wrapper">
                            <div class="bx--text-input__field-wrapper">
                                <input asp-for="Subject" class="bx--text-input" id="mailSubject" />
                            </div>
                        </div>
                    </div>

                    <div class="bx--form-item mb-4">
                        <label asp-for="HtmlBody" class="bx--label">HTML Body</label>
                        <div class="bx--text-area__wrapper">
                            <textarea asp-for="HtmlBody" class="bx--text-area" rows="8" id="mailBody"></textarea>
                        </div>
                    </div>
                </div>

                <div style="margin-top: 2rem; display: flex; gap: 1rem;">
                    <button type="submit" class="bx--btn bx--btn--primary" onclick="return confirm('Are you sure you want to send this email?');">Send Email</button>
                    <a href="@Url.Action("Index")" class="bx--btn bx--btn--secondary">Back to Dashboard</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('templateSelect').addEventListener('change', function() {
            var selectedOption = this.options[this.selectedIndex];
            var customFields = document.getElementById('customEmailFields');
            if (this.value) {
                // If template selected, we can hide the custom fields or make them readonly
                document.getElementById('mailSubject').value = selectedOption.getAttribute('data-subject') || '';
                document.getElementById('mailBody').value = selectedOption.getAttribute('data-body') || '';
                customFields.style.opacity = "0.5";
                document.getElementById('mailSubject').readOnly = true;
                document.getElementById('mailBody').readOnly = true;
            } else {
                document.getElementById('mailSubject').value = '';
                document.getElementById('mailBody').value = '';
                customFields.style.opacity = "1";
                document.getElementById('mailSubject').readOnly = false;
                document.getElementById('mailBody').readOnly = false;
            }
        });
    </script>
}
