@model NexClone.Backend.Controllers.MailingSettingsViewModel
@{
    ViewData["Title"] = "Mailing Settings";
}

<div class="bx--grid">
    <div class="bx--row">
        <div class="bx--col-lg-8">
            <h2 class="mb-4">Brevo Mailing Settings</h2>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="bx--inline-notification bx--inline-notification--success mb-4" role="alert">
                    <div class="bx--inline-notification__details">
                        <svg focusable="false" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="bx--inline-notification__icon" width="20" height="20" viewBox="0 0 20 20" aria-hidden="true"><path d="M10,1c-4.9,0-9,4.1-9,9s4.1,9,9,9s9-4.1,9-9S14.9,1,10,1z M8.7,13.5l-3.2-3.2l1-1l2.2,2.2l4.8-4.8l1,1L8.7,13.5z"></path></svg>
                        <div class="bx--inline-notification__text-wrapper">
                            <p class="bx--inline-notification__title">Success</p>
                            <p class="bx--inline-notification__subtitle">@TempData["SuccessMessage"]</p>
                        </div>
                    </div>
                </div>
            }

            <form asp-action="Settings" method="post" style="background: #fff; padding: 2rem; border-radius: 8px; border: 1px solid #e0e0e0;">
                <div class="bx--form-item mb-4">
                    <label asp-for="ApiKey" class="bx--label">Brevo API Key (v3)</label>
                    <div class="bx--text-input__field-outer-wrapper">
                        <div class="bx--text-input__field-wrapper">
                            <input asp-for="ApiKey" type="password" class="bx--text-input" placeholder="xkeysib-..." />
                        </div>
                    </div>
                </div>

                <div class="bx--form-item mb-4">
                    <label asp-for="SenderName" class="bx--label">Sender Name</label>
                    <div class="bx--text-input__field-outer-wrapper">
                        <div class="bx--text-input__field-wrapper">
                            <input asp-for="SenderName" type="text" class="bx--text-input" placeholder="e.g. NexMedia Support" />
                        </div>
                    </div>
                </div>

                <div class="bx--form-item mb-4">
                    <label asp-for="SenderEmail" class="bx--label">Sender Email Address</label>
                    <div class="bx--text-input__field-outer-wrapper">
                        <div class="bx--text-input__field-wrapper">
                            <input asp-for="SenderEmail" type="email" class="bx--text-input" placeholder="noreply@yourdomain.com" />
                        </div>
                    </div>
                </div>

                <div style="margin-top: 2rem; display: flex; gap: 1rem;">
                    <button type="submit" class="bx--btn bx--btn--primary">Save Settings</button>
                    <a href="@Url.Action("Index")" class="bx--btn bx--btn--secondary">Back to Dashboard</a>
                </div>
            </form>
        </div>
    </div>
</div>
