@model IEnumerable<NexClone.Backend.Models.ApiConfiguration>

<div class="bx--grid">
    <div class="bx--row" style="margin-bottom: 1rem;">
        <div class="bx--col">
            <a href="/ApiConfigAdmin/Create" class="bx--btn bx--btn--primary">Add New API Key</a>
        </div>
    </div>

    <div class="bx--row">
        <div class="bx--col">
            <table class="bx--data-table">
                <thead>
                    <tr>
                        <th>Provider</th>
                        <th>API Key</th>
                        <th>Status</th>
                        <th>Updated At</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.ProviderName</strong></td>
                            <td>
                                @if (item.ApiKey.Length > 10)
                                {
                                    @($"{item.ApiKey.Substring(0, 5)}...{item.ApiKey.Substring(item.ApiKey.Length - 5)}")
                                }
                                else
                                {
                                    @item.ApiKey
                                }
                            </td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span style="color: #24a148; font-weight: bold;">Active</span>
                                }
                                else
                                {
                                    <span style="color: #da1e28; font-weight: bold;">Inactive</span>
                                }
                            </td>
                            <td>@item.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <a href="/ApiConfigAdmin/Edit/@item.Id" class="bx--btn bx--btn--sm bx--btn--ghost">Edit</a>
                                <form action="/ApiConfigAdmin/Delete/@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this key?');">
                                    <button type="submit" class="bx--btn bx--btn--sm bx--btn--danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
