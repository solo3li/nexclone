@model NexClone.Backend.Models.ApiConfiguration

<div class="bx--grid">
    <div class="bx--row">
        <div class="bx--col-lg-8">
            <form action="/ApiConfigAdmin/Create" method="post">
                @Html.AntiForgeryToken()
                
                <div class="bx--form-item" style="margin-bottom: 1.5rem;">
                    <label for="ProviderName" class="bx--label">Provider</label>
                    <div class="bx--select">
                        <select id="ProviderName" name="ProviderName" class="bx--select-input" required>
                            <option value="" disabled selected hidden>Choose a Provider</option>
                            <option value="OpenAI">OpenAI</option>
                            <option value="Darijat">Darijat</option>
                            <option value="Gemini">Gemini</option>
                        </select>
                        <svg focusable="false" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg" fill="currentColor" aria-hidden="true" width="16" height="16" viewBox="0 0 16 16" class="bx--select__arrow"><path d="M8 11L3 6 3.7 5.3 8 9.6 12.3 5.3 13 6z"></path></svg>
                    </div>
                </div>

                <div class="bx--form-item" style="margin-bottom: 1.5rem;">
                    <label for="ApiKey" class="bx--label">API Key</label>
                    <input id="ApiKey" name="ApiKey" type="text" class="bx--text-input" required />
                </div>

                <div class="bx--form-item" style="margin-bottom: 1.5rem;">
                    <label for="BaseUrl" class="bx--label">Base URL (Optional)</label>
                    <input id="BaseUrl" name="BaseUrl" type="text" class="bx--text-input" />
                </div>

                <div class="bx--form-item" style="margin-bottom: 1.5rem;">
                    <div class="bx--checkbox-wrapper">
                        <input id="IsActive" name="IsActive" type="checkbox" value="true" class="bx--checkbox" checked />
                        <label for="IsActive" class="bx--checkbox-label">Is Active</label>
                        <!-- Checkbox hidden input for false value handling in ASP.NET -->
                        <input type="hidden" name="IsActive" value="false" />
                    </div>
                </div>

                <div class="bx--form-item" style="margin-bottom: 1.5rem;">
                    <label for="AdditionalSettings" class="bx--label">Additional Settings (JSON - Optional)</label>
                    <textarea id="AdditionalSettings" name="AdditionalSettings" class="bx--text-area" rows="4"></textarea>
                </div>

                <div class="bx--form-item">
                    <button type="submit" class="bx--btn bx--btn--primary">Save</button>
                    <a href="/ApiConfigAdmin" class="bx--btn bx--btn--secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
