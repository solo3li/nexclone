@model IEnumerable<NexClone.Backend.Models.Legacy.SubscriptionsPlan>

@{
    ViewData["Title"] = "Pricing Plans";
}

<div class="bx--data-table-container">
    <div class="bx--data-table-header">
        <h4 class="bx--data-table-header__title">Manage Pricing Plans</h4>
        <p class="bx--data-table-header__description">View and manage all subscription plans imported from the legacy database.</p>
    </div>

    <!-- Carbon Data Table -->
    <table class="bx--data-table bx--data-table--sort">
        <thead>
            <tr>
                <th><span class="bx--table-header-label">ID</span></th>
                <th><span class="bx--table-header-label">Plan Name</span></th>
                <th><span class="bx--table-header-label">Duration (Days)</span></th>
                <th><span class="bx--table-header-label">Price (USD)</span></th>
                <th><span class="bx--table-header-label">Price (EGP)</span></th>
                <th><span class="bx--table-header-label">Created At</span></th>
                <th><span class="bx--table-header-label">Actions</span></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td><strong>@item.Name</strong></td>
                    <td>@item.DurationDays</td>
                    <td>$@item.PriceUsd</td>
                    <td>EGP @item.PriceEgp</td>
                    <td>@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                    <td>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this plan?');">
                            <button type="submit" class="bx--btn bx--btn--danger bx--btn--sm" style="padding: 5px 10px; font-size: 12px; height: auto; min-height: unset;">
                                Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
