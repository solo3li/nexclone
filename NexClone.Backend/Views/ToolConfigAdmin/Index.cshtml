@model Dictionary<string, NexClone.Backend.Models.ToolConfiguration>

@{
    ViewData["Title"] = "Tool Settings";
    var providers = ViewBag.Providers as SelectList;
}

<div class="bx--grid bx--grid--full-width">
    <div class="bx--row" style="margin-bottom: 2rem;">
        <div class="bx--col">
            <h1 class="bx--type-productive-heading-05">Advanced Tool Configurations</h1>
            <p style="margin-top: 0.5rem; color: #525252;">Manage individual settings, scheduling, and fallbacks for each tool independently.</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div data-notification class="bx--inline-notification bx--inline-notification--success" role="alert" style="margin-bottom: 1rem;">
            <div class="bx--inline-notification__details">
                <svg focusable="false" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="bx--inline-notification__icon" width="20" height="20" viewBox="0 0 20 20" aria-hidden="true"><path d="M10,1c-4.9,0-9,4.1-9,9s4.1,9,9,9s9-4.1,9-9S14.9,1,10,1z M8.7,13.5l-3.2-3.2l1-1l2.2,2.2l4.8-4.8l1,1L8.7,13.5z"></path></svg>
                <div class="bx--inline-notification__text-wrapper">
                    <p class="bx--inline-notification__title">Success</p>
                    <p class="bx--inline-notification__subtitle">@TempData["SuccessMessage"]</p>
                </div>
            </div>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div data-notification class="bx--inline-notification bx--inline-notification--error" role="alert" style="margin-bottom: 1rem;">
            <div class="bx--inline-notification__details">
                <svg focusable="false" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="bx--inline-notification__icon" width="20" height="20" viewBox="0 0 20 20" aria-hidden="true"><path d="M10,1c-5,0-9,4-9,9s4,9,9,9s9-4,9-9S15,1,10,1z M13.5,14.5l-8-8l1-1l8,8L13.5,14.5z"></path></svg>
                <div class="bx--inline-notification__text-wrapper">
                    <p class="bx--inline-notification__title">Error</p>
                    <p class="bx--inline-notification__subtitle">@TempData["ErrorMessage"]</p>
                </div>
            </div>
        </div>
    }

    <div class="bx--row">
        <div class="bx--col">
            <div data-tabs class="bx--tabs">
                <ul class="bx--tabs__nav bx--tabs__nav--hidden" role="tablist">
                    @{ int i = 0; }
                    @foreach (var tool in Model.Keys)
                    {
                        <li class="bx--tabs__nav-item @(i == 0 ? "bx--tabs__nav-item--selected" : "")" data-target=".tab-panel-@tool" role="tab" aria-selected="@(i == 0 ? "true" : "false")">
                            <a tabindex="0" id="tab-link-@tool" class="bx--tabs__nav-link" href="javascript:void(0)" role="tab" aria-controls="tab-panel-@tool">
                                @tool.ToUpper().Replace("-", " ")
                            </a>
                        </li>
                        i++;
                    }
                </ul>
            </div>
        </div>
    </div>

    @{ int j = 0; }
    @foreach (var kvp in Model)
    {
        var toolName = kvp.Key;
        var config = kvp.Value;
        
        <div id="tab-panel-@toolName" class="tab-panel-@toolName" role="tabpanel" aria-labelledby="tab-link-@toolName" aria-hidden="@(j == 0 ? "false" : "true")" @(j != 0 ? "hidden" : "")>
            <div class="bx--row" style="margin-top: 2rem;">
                <div class="bx--col-lg-12">
                    <form asp-action="SaveConfig" method="post" class="bx--form">
                        <input type="hidden" name="ToolName" value="@toolName" />
                        
                        <div style="background: #f4f4f4; padding: 2rem; border: 1px solid #e0e0e0; margin-bottom: 2rem;">
                            <h3 class="bx--type-productive-heading-03" style="margin-bottom: 1.5rem;">General Settings</h3>
                            
                            <div class="bx--form-item" style="margin-bottom: 1.5rem;">
                                <div class="bx--toggle-c">
                                    <input type="checkbox" id="IsActive-@toolName" class="bx--toggle-input" name="IsActive" value="true" @(config.IsActive ? "checked" : "")>
                                    <input type="hidden" name="IsActive" value="false">
                                    <label for="IsActive-@toolName" class="bx--toggle-input__label" aria-label="Toggle">
                                        <span class="bx--toggle__switch">
                                            <span class="bx--toggle__text--left" aria-hidden="true">Off</span>
                                            <span class="bx--toggle__text--right" aria-hidden="true">On</span>
                                        </span>
                                        <span style="margin-left: 1rem;">Is Active (Enable/Disable Tool)</span>
                                    </label>
                                </div>
                            </div>

                            <div class="bx--form-item">
                                <div class="bx--toggle-c">
                                    <input type="checkbox" id="IsMaintenanceMode-@toolName" class="bx--toggle-input" name="IsMaintenanceMode" value="true" @(config.IsMaintenanceMode ? "checked" : "")>
                                    <input type="hidden" name="IsMaintenanceMode" value="false">
                                    <label for="IsMaintenanceMode-@toolName" class="bx--toggle-input__label" aria-label="Toggle">
                                        <span class="bx--toggle__switch">
                                            <span class="bx--toggle__text--left" aria-hidden="true">Off</span>
                                            <span class="bx--toggle__text--right" aria-hidden="true">On</span>
                                        </span>
                                        <span style="margin-left: 1rem;">Maintenance Mode</span>
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                            <h3 class="bx--type-productive-heading-03">Routing Rules (Models)</h3>
                            <button type="button" class="bx--btn bx--btn--sm bx--btn--secondary" onclick="addRule('@toolName')">
                                + Add Model
                            </button>
                        </div>
                        
                        <div id="rules-container-@toolName" style="display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2rem;">
                            @{
                                var sortedRules = config.RoutingRules?.ToList() ?? new List<NexClone.Backend.Models.ToolRoutingRule>();
                            }
                            @for (int r = 0; r < sortedRules.Count; r++)
                            {
                                var rule = sortedRules[r];
                                <div class="rule-block" style="background: #ffffff; padding: 1.5rem; border: 1px solid #e0e0e0; border-left: 4px solid #0f62fe; position: relative;">
                                    <button type="button" class="bx--btn bx--btn--sm bx--btn--danger" style="position: absolute; top: 1rem; right: 1rem;" onclick="this.closest('.rule-block').remove(); updateRuleIndices('@toolName');">
                                        Remove
                                    </button>
                                    
                                    @if (toolName == "text-to-voice")
                                    {
                                        <div class="bx--form-item" style="margin-bottom: 1rem;">
                                            <label class="bx--label">Quality Level</label>
                                            <select name="RoutingRules[@r].QualityLevel" class="bx--select-input rule-quality-input" required>
                                                <option value="Standard" selected="@(rule.QualityLevel == "Standard")">Standard</option>
                                                <option value="High" selected="@(rule.QualityLevel == "High")">High</option>
                                            </select>
                                        </div>
                                    }
                                    else
                                    {
                                        <input type="hidden" name="RoutingRules[@r].QualityLevel" value="Standard" class="rule-quality-input" />
                                    }
                                    
                                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                                        <div class="bx--form-item">
                                            <label class="bx--label">Provider Name</label>
                                            <select name="RoutingRules[@r].ProviderName" class="bx--select-input" required>
                                                <option value="">-- Select Provider --</option>
                                                @if (providers != null)
                                                {
                                                    foreach (var p in providers)
                                                    {
                                                        <option value="@p.Text" selected="@(rule.ProviderName == p.Text)">@p.Text</option>
                                                    }
                                                }
                                            </select>
                                        </div>
                                        <div class="bx--form-item">
                                            <label class="bx--label">Model Name (Optional)</label>
                                            <input type="text" name="RoutingRules[@r].ModelName" class="bx--text-input" value="@rule.ModelName" placeholder="e.g. tts-1 or gemini-2.0" />
                                        </div>
                                    </div>
                                    
                                    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem;">
                                        <div class="bx--form-item">
                                            <label class="bx--label">Max Daily Requests</label>
                                            <input type="number" name="RoutingRules[@r].MaxDailyRequests" class="bx--text-input" value="@rule.MaxDailyRequests" placeholder="Unlimited" min="1" />
                                        </div>
                                        <div class="bx--form-item">
                                            <label class="bx--label">Max Requests/Min</label>
                                            <input type="number" name="RoutingRules[@r].MaxRequestsPerMinute" class="bx--text-input" value="@rule.MaxRequestsPerMinute" placeholder="Unlimited" min="1" />
                                        </div>
                                        <div class="bx--form-item">
                                            <label class="bx--label">Active From Time</label>
                                            <input type="time" name="RoutingRules[@r].ActiveFromTime" class="bx--text-input" value="@(rule.ActiveFromTime.HasValue ? rule.ActiveFromTime.Value.ToString(@"hh\:mm") : "")" />
                                        </div>
                                        <div class="bx--form-item">
                                            <label class="bx--label">Active To Time</label>
                                            <input type="time" name="RoutingRules[@r].ActiveToTime" class="bx--text-input" value="@(rule.ActiveToTime.HasValue ? rule.ActiveToTime.Value.ToString(@"hh\:mm") : "")" />
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        <button type="submit" class="bx--btn bx--btn--primary">Save @toolName.ToUpper() Settings</button>
                    </form>
                </div>
            </div>
        </div>
        j++;
    }
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const tabs = document.querySelectorAll('.bx--tabs__nav-item');
            
            tabs.forEach(tab => {
                tab.addEventListener('click', function() {
                    // Remove selected class from all tabs
                    tabs.forEach(t => t.classList.remove('bx--tabs__nav-item--selected'));
                    // Add selected class to clicked tab
                    this.classList.add('bx--tabs__nav-item--selected');
                    
                    // Hide all panels
                    document.querySelectorAll('[role="tabpanel"]').forEach(panel => {
                        panel.setAttribute('hidden', 'true');
                        panel.setAttribute('aria-hidden', 'true');
                    });
                    
                    // Show target panel
                    const target = this.getAttribute('data-target');
                    const targetPanel = document.querySelector(target);
                    if (targetPanel) {
                        targetPanel.removeAttribute('hidden');
                        targetPanel.setAttribute('aria-hidden', 'false');
                    }
                });
            });
        });

        // Provider options rendered as a JS array
        const providerOptions = [
            @if (providers != null)
            {
                foreach (var p in providers)
                {
                    <text>
                    { value: '@p.Text', text: '@p.Text' },
                    </text>
                }
            }
        ];

        window.addRule = function(toolName) {
            const container = document.getElementById(`rules-container-${toolName}`);
            const count = container.querySelectorAll('.rule-block').length;
            
            let optionsHtml = '<option value="">-- Select Provider --</option>';
            providerOptions.forEach(p => {
                optionsHtml += `<option value="${p.value}">${p.text}</option>`;
            });

            const html = `
                <div class="rule-block" style="background: #ffffff; padding: 1.5rem; border: 1px solid #e0e0e0; border-left: 4px solid #0f62fe; position: relative;">
                    <button type="button" class="bx--btn bx--btn--sm bx--btn--danger" style="position: absolute; top: 1rem; right: 1rem;" onclick="this.closest('.rule-block').remove(); updateRuleIndices('${toolName}');">
                        Remove
                    </button>
                    
                    ${toolName === "text-to-voice" ? `
                    <div class="bx--form-item" style="margin-bottom: 1rem;">
                        <label class="bx--label">Quality Level</label>
                        <select name="RoutingRules[${count}].QualityLevel" class="bx--select-input rule-quality-input" required>
                            <option value="Standard">Standard</option>
                            <option value="High">High</option>
                        </select>
                    </div>
                    ` : `<input type="hidden" name="RoutingRules[${count}].QualityLevel" value="Standard" class="rule-quality-input" />`}
                    
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                        <div class="bx--form-item">
                            <label class="bx--label">Provider Name</label>
                            <select name="RoutingRules[${count}].ProviderName" class="bx--select-input" required>
                                ${optionsHtml}
                            </select>
                        </div>
                        <div class="bx--form-item">
                            <label class="bx--label">Model Name (Optional)</label>
                            <input type="text" name="RoutingRules[${count}].ModelName" class="bx--text-input" placeholder="e.g. tts-1 or gemini-2.0" />
                        </div>
                    </div>
                    
                    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem;">
                        <div class="bx--form-item">
                            <label class="bx--label">Max Daily Requests</label>
                            <input type="number" name="RoutingRules[${count}].MaxDailyRequests" class="bx--text-input" placeholder="Unlimited" min="1" />
                        </div>
                        <div class="bx--form-item">
                            <label class="bx--label">Max Requests/Min</label>
                            <input type="number" name="RoutingRules[${count}].MaxRequestsPerMinute" class="bx--text-input" placeholder="Unlimited" min="1" />
                        </div>
                        <div class="bx--form-item">
                            <label class="bx--label">Active From Time</label>
                            <input type="time" name="RoutingRules[${count}].ActiveFromTime" class="bx--text-input" />
                        </div>
                        <div class="bx--form-item">
                            <label class="bx--label">Active To Time</label>
                            <input type="time" name="RoutingRules[${count}].ActiveToTime" class="bx--text-input" />
                        </div>
                    </div>
                </div>
            `;
            
            container.insertAdjacentHTML('beforeend', html);
        };

        window.updateRuleIndices = function(toolName) {
            const container = document.getElementById(`rules-container-${toolName}`);
            const blocks = container.querySelectorAll('.rule-block');
            
            blocks.forEach((block, index) => {
                const qualityInput = block.querySelector('.rule-quality-input');
                if (qualityInput) qualityInput.name = `RoutingRules[${index}].QualityLevel`;
                
                block.querySelector('select[name^="RoutingRules"][name$=".ProviderName"]').name = `RoutingRules[${index}].ProviderName`;
                block.querySelector('input[name$=".ModelName"]').name = `RoutingRules[${index}].ModelName`;
                block.querySelector('input[name$=".MaxDailyRequests"]').name = `RoutingRules[${index}].MaxDailyRequests`;
                
                const rpmInput = block.querySelector('input[name$=".MaxRequestsPerMinute"]');
                if (rpmInput) rpmInput.name = `RoutingRules[${index}].MaxRequestsPerMinute`;
                
                block.querySelector('input[name$=".ActiveFromTime"]').name = `RoutingRules[${index}].ActiveFromTime`;
                block.querySelector('input[name$=".ActiveToTime"]').name = `RoutingRules[${index}].ActiveToTime`;
            });
        };
    </script>
}
