@model Dictionary<string, NexClone.Backend.Models.ToolConfiguration>

@{
    ViewData["Title"] = "Tool Settings";
    var providers = ViewBag.Providers as SelectList;
}

<div class="bx--grid bx--grid--full-width">
    <div class="bx--row" style="margin-bottom: 2rem;">
        <div class="bx--col">
            <h1 class="bx--type-productive-heading-05">Advanced Tool Configurations</h1>
            <p style="margin-top: 0.5rem; color: #525252;">Manage individual settings, scheduling, and fallbacks for each tool independently.</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div data-notification class="bx--inline-notification bx--inline-notification--success" role="alert" style="margin-bottom: 1rem;">
            <div class="bx--inline-notification__details">
                <svg focusable="false" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="bx--inline-notification__icon" width="20" height="20" viewBox="0 0 20 20" aria-hidden="true"><path d="M10,1c-4.9,0-9,4.1-9,9s4.1,9,9,9s9-4.1,9-9S14.9,1,10,1z M8.7,13.5l-3.2-3.2l1-1l2.2,2.2l4.8-4.8l1,1L8.7,13.5z"></path></svg>
                <div class="bx--inline-notification__text-wrapper">
                    <p class="bx--inline-notification__title">Success</p>
                    <p class="bx--inline-notification__subtitle">@TempData["SuccessMessage"]</p>
                </div>
            </div>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div data-notification class="bx--inline-notification bx--inline-notification--error" role="alert" style="margin-bottom: 1rem;">
            <div class="bx--inline-notification__details">
                <svg focusable="false" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="bx--inline-notification__icon" width="20" height="20" viewBox="0 0 20 20" aria-hidden="true"><path d="M10,1c-5,0-9,4-9,9s4,9,9,9s9-4,9-9S15,1,10,1z M13.5,14.5l-8-8l1-1l8,8L13.5,14.5z"></path></svg>
                <div class="bx--inline-notification__text-wrapper">
                    <p class="bx--inline-notification__title">Error</p>
                    <p class="bx--inline-notification__subtitle">@TempData["ErrorMessage"]</p>
                </div>
            </div>
        </div>
    }

    <div class="bx--row">
        <div class="bx--col">
            <div data-tabs class="bx--tabs">
                <ul class="bx--tabs__nav bx--tabs__nav--hidden" role="tablist">
                    @{ int i = 0; }
                    @foreach (var tool in Model.Keys)
                    {
                        <li class="bx--tabs__nav-item @(i == 0 ? "bx--tabs__nav-item--selected" : "")" data-target=".tab-panel-@tool" role="tab" aria-selected="@(i == 0 ? "true" : "false")">
                            <a tabindex="0" id="tab-link-@tool" class="bx--tabs__nav-link" href="javascript:void(0)" role="tab" aria-controls="tab-panel-@tool">
                                @tool.ToUpper().Replace("-", " ")
                            </a>
                        </li>
                        i++;
                    }
                </ul>
            </div>
        </div>
    </div>

    @{ int j = 0; }
    @foreach (var kvp in Model)
    {
        var toolName = kvp.Key;
        var config = kvp.Value;
        
        <div id="tab-panel-@toolName" class="tab-panel-@toolName" role="tabpanel" aria-labelledby="tab-link-@toolName" aria-hidden="@(j == 0 ? "false" : "true")" @(j != 0 ? "hidden" : "")>
            <div class="bx--row" style="margin-top: 2rem;">
                <div class="bx--col-lg-12">
                    <form asp-action="SaveConfig" method="post" class="bx--form">
                        <input type="hidden" name="ToolName" value="@toolName" />
                        
                        <div style="background: #f4f4f4; padding: 2rem; border: 1px solid #e0e0e0; margin-bottom: 2rem;">
                            <h3 class="bx--type-productive-heading-03" style="margin-bottom: 1.5rem;">General Settings</h3>
                            
                            <div class="bx--form-item" style="margin-bottom: 1.5rem;">
                                <div class="bx--toggle-c">
                                    <input type="checkbox" id="IsActive-@toolName" class="bx--toggle-input" name="IsActive" value="true" @(config.IsActive ? "checked" : "")>
                                    <input type="hidden" name="IsActive" value="false">
                                    <label for="IsActive-@toolName" class="bx--toggle-input__label" aria-label="Toggle">
                                        <span class="bx--toggle__switch">
                                            <span class="bx--toggle__text--left" aria-hidden="true">Off</span>
                                            <span class="bx--toggle__text--right" aria-hidden="true">On</span>
                                        </span>
                                        <span style="margin-left: 1rem;">Is Active (Enable/Disable Tool)</span>
                                    </label>
                                </div>
                            </div>

                            <div class="bx--form-item">
                                <div class="bx--toggle-c">
                                    <input type="checkbox" id="IsMaintenanceMode-@toolName" class="bx--toggle-input" name="IsMaintenanceMode" value="true" @(config.IsMaintenanceMode ? "checked" : "")>
                                    <input type="hidden" name="IsMaintenanceMode" value="false">
                                    <label for="IsMaintenanceMode-@toolName" class="bx--toggle-input__label" aria-label="Toggle">
                                        <span class="bx--toggle__switch">
                                            <span class="bx--toggle__text--left" aria-hidden="true">Off</span>
                                            <span class="bx--toggle__text--right" aria-hidden="true">On</span>
                                        </span>
                                        <span style="margin-left: 1rem;">Maintenance Mode</span>
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 2rem;">
                            <!-- Primary Provider -->
                            <div style="background: #ffffff; padding: 2rem; border: 1px solid #8a3ffc; border-top: 4px solid #8a3ffc;">
                                <h3 class="bx--type-productive-heading-03" style="margin-bottom: 1.5rem; color: #8a3ffc;">Primary Provider</h3>
                                
                                <div class="bx--form-item" style="margin-bottom: 1rem;">
                                    <label class="bx--label">Provider Name</label>
                                    <select name="ProviderName" class="bx--select-input">
                                        <option value="">-- Select Provider --</option>
                                        @if (providers != null)
                                        {
                                            foreach (var p in providers)
                                            {
                                                <option value="@p.Text" selected="@(config.ProviderName == p.Text)">@p.Text</option>
                                            }
                                        }
                                    </select>
                                </div>

                                <div class="bx--form-item" style="margin-bottom: 1rem;">
                                    <label class="bx--label">Model Name (Optional)</label>
                                    <input type="text" name="ModelName" class="bx--text-input" value="@config.ModelName" placeholder="e.g. tts-1 or gemini-2.0" />
                                </div>

                                <h4 class="bx--type-productive-heading-01" style="margin-top: 1.5rem; margin-bottom: 1rem;">Usage Limits (Optional)</h4>
                                
                                <div class="bx--form-item" style="margin-bottom: 1rem;">
                                    <label class="bx--label">Max Daily Requests</label>
                                    <input type="number" name="MaxDailyRequests" class="bx--text-input" value="@config.MaxDailyRequests" placeholder="Leave empty for unlimited" min="1" />
                                    <div class="bx--form__helper-text">Switches to fallback if daily limit exceeded.</div>
                                </div>

                                <div style="display: flex; gap: 1rem;">
                                    <div class="bx--form-item" style="flex: 1;">
                                        <label class="bx--label">Active From Time</label>
                                        <input type="time" name="ActiveFromTime" class="bx--text-input" value="@(config.ActiveFromTime.HasValue ? config.ActiveFromTime.Value.ToString(@"hh\:mm") : "")" />
                                    </div>
                                    <div class="bx--form-item" style="flex: 1;">
                                        <label class="bx--label">Active To Time</label>
                                        <input type="time" name="ActiveToTime" class="bx--text-input" value="@(config.ActiveToTime.HasValue ? config.ActiveToTime.Value.ToString(@"hh\:mm") : "")" />
                                    </div>
                                </div>
                                <div class="bx--form__helper-text">Format: HH:MM. Provider will only be used within this window. Outside this window, fallback will be used.</div>
                            </div>

                            <!-- Fallback Provider -->
                            <div style="background: #ffffff; padding: 2rem; border: 1px solid #da1e28; border-top: 4px solid #da1e28;">
                                <h3 class="bx--type-productive-heading-03" style="margin-bottom: 1.5rem; color: #da1e28;">Fallback Provider</h3>
                                
                                <div class="bx--form-item" style="margin-bottom: 1rem;">
                                    <label class="bx--label">Provider Name</label>
                                    <select name="FallbackProviderName" class="bx--select-input">
                                        <option value="">-- No Fallback --</option>
                                        @if (providers != null)
                                        {
                                            foreach (var p in providers)
                                            {
                                                <option value="@p.Text" selected="@(config.FallbackProviderName == p.Text)">@p.Text</option>
                                            }
                                        }
                                    </select>
                                    <div class="bx--form__helper-text">Used if primary fails, hits request limit, or is outside scheduled hours.</div>
                                </div>

                                <div class="bx--form-item">
                                    <label class="bx--label">Model Name (Optional)</label>
                                    <input type="text" name="FallbackModelName" class="bx--text-input" value="@config.FallbackModelName" />
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="bx--btn bx--btn--primary">Save @toolName.ToUpper() Settings</button>
                    </form>
                </div>
            </div>
        </div>
        j++;
    }
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const tabs = document.querySelectorAll('.bx--tabs__nav-item');
            
            tabs.forEach(tab => {
                tab.addEventListener('click', function() {
                    // Remove selected class from all tabs
                    tabs.forEach(t => t.classList.remove('bx--tabs__nav-item--selected'));
                    // Add selected class to clicked tab
                    this.classList.add('bx--tabs__nav-item--selected');
                    
                    // Hide all panels
                    document.querySelectorAll('[role="tabpanel"]').forEach(panel => {
                        panel.setAttribute('hidden', 'true');
                        panel.setAttribute('aria-hidden', 'true');
                    });
                    
                    // Show target panel
                    const target = this.getAttribute('data-target');
                    const targetPanel = document.querySelector(target);
                    if (targetPanel) {
                        targetPanel.removeAttribute('hidden');
                        targetPanel.setAttribute('aria-hidden', 'false');
                    }
                });
            });
        });
    </script>
}
