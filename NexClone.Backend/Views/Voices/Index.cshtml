@model IEnumerable<NexClone.Backend.Models.Voice>

@{
    ViewData["Title"] = "AI Voices Management";
}

<div class="bx--data-table-container">
    <div class="bx--data-table-header">
        <h4 class="bx--data-table-header__title">Manage AI Voices</h4>
        <p class="bx--data-table-header__description">View and manage all available AI voice characters imported from the legacy system.</p>
    </div>

    <table class="bx--data-table bx--data-table--sort">
        <thead>
            <tr>
                <th><span class="bx--table-header-label">ID</span></th>
                <th><span class="bx--table-header-label">Name</span></th>
                <th><span class="bx--table-header-label">Gender</span></th>
                <th><span class="bx--table-header-label">Premium</span></th>
                <th><span class="bx--table-header-label">Active</span></th>
                <th><span class="bx--table-header-label">Gemini Voice</span></th>
                <th><span class="bx--table-header-label">Actions</span></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td><strong>@item.Name</strong></td>
                    <td>@item.Gender</td>
                    <td>@(item.IsPremium ? "Yes" : "No")</td>
                    <td>
                        <span style="color: @(item.IsActive ? "green" : "red");">
                            @(item.IsActive ? "Active" : "Inactive")
                        </span>
                    </td>
                    <td>@item.GeminiVoice</td>
                    <td>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this voice?');">
                            <button type="submit" class="bx--btn bx--btn--danger bx--btn--sm" style="padding: 5px 10px; font-size: 12px; height: auto; min-height: unset;">
                                Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
